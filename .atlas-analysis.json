  "keyFeatures": [
    "Zero-trust policy enforcement for AI agent tool calls",
    "Cryptographic agent identity attestation with AAT tokens",
    "Human-in-the-loop approval for sensitive operations",
    "DLP scanning for preventing data exfiltration",
    "Immutable audit logging for SOC 2, GDPR, HIPAA compliance",
    "Transparent proxy for Model Context Protocol (MCP) servers",
    "Fine-grained per-tool and per-argument authorization"
  ],
  "publicApiSurface": [
    "AgentPolicy YAML schema (v1alpha1, v1alpha2)",
    "Agent Authentication Token (AAT) format",
    "Agent Identity Document (AID) structure",
    "JSON-RPC error codes (-32001 Permission Denied, -32002 Human Approval Required)",
    "HTTP validation endpoints (/v1/validate)",
    "Audit log JSONL format",
    "Policy signing with Ed25519",
    "Conformance test suite (basic, full, extended, identity, server levels)",
    "DLP pattern configuration (regex-based)",
    "Tool rules: allow, block, ask actions"
  ]
